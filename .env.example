# Copy this file to .env and fill in what you need. .env is git-ignored and
# is the single place for secrets — scripts propagate values where required
# (e.g. OPENAI_API_KEY into supabase/functions/.env for the Edge Runtime).
#
# Project identity (ref, region, hosted URL) is configured in
# script/common.sh, not here.

# --- AI question generation (optional) ---------------------------------------
# Without it the app runs fine, but creating a new game returns a 503.
OPENAI_API_KEY=

# --- Downloading production data (optional, read-only) ------------------------
# script/download-supabase-database-dump: just the database password —
# host/user are derived from the project ref + region. The password is
# write-only in Supabase (no CLI/API can read it back); if unknown:
# Dashboard → Project Settings → Database → Reset database password.
SUPABASE_DB_PASSWORD=

# Alternative: full "Session pooler" connection string (Dashboard → Connect →
# Session pooler). Overrides SUPABASE_DB_PASSWORD; only needed if your pooler
# host isn't one the script tries automatically.
SUPABASE_DB_URL=

# script/download-supabase-storage: the service_role key (Dashboard →
# Project Settings → API keys → service_role). Bypasses Storage policies to
# read private buckets — treat like a password.
SUPABASE_SERVICE_ROLE_KEY=

# --- Frontend target (optional) ----------------------------------------------
# Leave empty. script/server injects the LOCAL stack's URL/key automatically;
# when unset, the app falls back to the hosted project (values are hardcoded
# as fallbacks in src/integrations/supabase/client.ts).
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
