#!/usr/bin/env bash
# script/setup — one-time install: deps, migrations, .env scaffold. Rerun-safe.

source "$(dirname "$0")/common.sh"

require_tools

if [ ! -f .env ]; then
  cp .env.example .env
  info "Created .env from .env.example — fill in secrets there (git-ignored)"
fi
load_env
sync_function_env

info "Installing npm dependencies into the Docker volume"
docker compose run --rm web npm ci

# Remember whether the Supabase stack was running so we can restore that state.
was_running=false
supabase_running && was_running=true

start_supabase

info "Applying any pending database migrations"
supabase migration up

verify_schema

count="$(games_count)"
if [ "$count" != "0" ]; then
  info "Database already has $count games; leaving data untouched"
elif snapshot_available; then
  restore_snapshot
else
  info "No local data snapshot found — database is empty (schema only)."
  info "Pull production data with: script/download-supabase-database-dump && script/bootstrap"
fi

if [ "$was_running" = false ]; then
  info "Stopping Supabase (it was not running before setup)"
  supabase stop
fi

info "Setup complete. Run script/server to start the app."
info "For fresh production data: script/download-supabase-database-dump && script/bootstrap"
